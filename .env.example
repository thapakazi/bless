# ClickHouse
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=bless
CLICKHOUSE_USER=bless
CLICKHOUSE_PASSWORD=bless

# Claude (Anthropic API) — primary LLM
ANTHROPIC_API_KEY=
# Per-role model overrides (defaults baked into code if unset)
CLAUDE_MODEL_ENRICHER=claude-sonnet-4-6
CLAUDE_MODEL_REPORTER=claude-opus-4-7
CLAUDE_MODEL_CHAT=claude-opus-4-7

# TrueFoundry (model serving, enrichment endpoint)
TRUEFOUNDRY_ENDPOINT=
TRUEFOUNDRY_API_KEY=

# Guild.ai (agent orchestration)
GUILD_API_KEY=

# Airbyte (data ingestion)
AIRBYTE_API_KEY=
AIRBYTE_WORKSPACE_ID=

# Composio (action execution)
COMPOSIO_API_KEY=
SLACK_CHANNEL=#general

# Langfuse (observability)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
